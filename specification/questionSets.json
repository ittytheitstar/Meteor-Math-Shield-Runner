  {
  "id": "probability_simple_events",
  "strand": "probability",
  "topic": "chance",
  "ageBand": ["age8_9", "age10_12"],
  "difficulty": {
    "min": 2,
    "max": 6,
    "steps": [
      { "level": 2, "context": "coin", "questions": ["likely_outcome", "probability_fraction"] },
      { "level": 3, "context": "dice", "questions": ["probability_fraction"] },
      { "level": 4, "context": "bag_of_colours", "withoutReplacement": false },
      { "level": 5, "context": "bag_of_colours", "withoutReplacement": true },
